# ──────────────────────────────────────
# GPS SMART KIOSK 통신 모듈 설정
# 이 파일을 복사해서 .env 로 저장하세요
# ──────────────────────────────────────

# 백엔드에서 키오스크 구분 (WebSocket PERSON_DETECTED 등)
KIOSK_ID=eccd04c5-0415-4367-af1b-3f75dce351eb

# 시리얼 포트 설정
SERIAL_PORT=COM3
SERIAL_BAUDRATE=115200
SERIAL_PORT_DESCRIPTION_KEYWORD=USB
VOLUME_SERIAL_PORT=COM5

# WebSocket (백엔드 연동 시 true)
WS_ENABLED=true
WS_URL=ws://192.168.0.213:3000/ws/kiosk/device_id/eccd04c5-0415-4367-af1b-3f75dce351eb
WS_RECONNECT_INTERVAL=5.0

# 상태 폴링 주기 (초)
STATUS_POLL_INTERVAL=2.0

# 사람 없음 + 입력 유휴 시 자동 도어 닫기 (초, INPUT_MONITOR_ENABLED 필요)
VACANT_IDLE_CLOSE_SECONDS=20.0

# 사람 최초 감지 시 스피커 ON + WS 이벤트
AUTO_SPEAKER_ON_PERSON=true
INPUT_MONITOR_ENABLED=true

# 오른쪽 버튼 Meet/웹 URL · 브라우저
MEET_WEB_URL=https://meet.jdone.co.kr/test1
KIOSK_BROWSER_CMD=
BACKGROUND_BROWSER_TIMEOUT_SECONDS=300

# 조명 자동 스케줄 (로컬 시각 HH:MM). AC·DC(디밍) 각각 "구간 안=ON, 밖=OFF".
# 채널별 START/END를 비우면 예전처럼 LIGHT_SCHEDULE_START / LIGHT_SCHEDULE_END 로 공통 폴백.
LIGHT_SCHEDULE_ENABLED=true
LIGHT_SCHEDULE_AC_ENABLED=true
LIGHT_SCHEDULE_AC_START=18:00
LIGHT_SCHEDULE_AC_END=08:00
LIGHT_SCHEDULE_DC_ENABLED=true
LIGHT_SCHEDULE_DC_START=18:00
LIGHT_SCHEDULE_DC_END=08:00

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO


tts_text="이리오너라. 합천 스마트 관광 키오스크 입니다. 점자 키패드를 사용하실 분은 왼쪽에 있는 커버 오픈을 눌러주세요."

tts_text2="관광 잘하거라."
PERSON_DETECTED_MP3_PATH=person_detected.mp3
PERSON_DETECTED_TTS_TEXT="이쪽으로 오이소. 합천 스마트 관광 키오스크 입니데이. 왼쪽 버튼 눌러주이소."
PERSON_DETECTED_TTS_LANG=ko
PERSON_DETECTED_TTS_AUTOGEN=true